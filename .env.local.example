# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Resend (invitation emails)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@licagent.app
RESEND_FROM_NAME=LIC Agent Management

# MSG91 (SMS)
MSG91_AUTH_KEY=
MSG91_SENDER_ID=LICAGT
MSG91_DEFAULT_TEMPLATE_ID=

# Cron (Vercel Cron + manual triggers)
CRON_SECRET=generate_a_long_random_secret

# Storage (create bucket in Supabase Dashboard → Storage)
SUPABASE_STORAGE_BUCKET_KYC=kyc-documents

# App (must match Supabase Auth Site URL and Redirect URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=LIC Agent Management
